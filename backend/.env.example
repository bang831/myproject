# ============================================================
# DeployFlow Backend - Environment Configuration
# Salin file ini ke .env dan isi sesuai kebutuhan
# ============================================================

# Server
PORT=4000
NODE_ENV=production

# JWT Secret - WAJIB ganti dengan string acak yang panjang!
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=ganti-ini-dengan-secret-yang-sangat-panjang-dan-acak

# CORS - domain frontend kamu
CORS_ORIGIN=http://localhost:5173

# Direktori apps (default: ~/apps)
APPS_DIR=/root/apps

# Nginx config directory
NGINX_DIR=/etc/nginx/sites-enabled

# Static files root
STATIC_ROOT=/var/www

# Port range untuk project apps
PORT_START=3100
PORT_END=3999

# Database path (default: ./database/panel.db)
DB_PATH=./database
